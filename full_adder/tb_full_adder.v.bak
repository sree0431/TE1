//testbench full-adder
//testbench

module tb_full_adder;
	//tb signals
	reg A, B, cin;
   	wire sum, cout;

	// half-adder instance
	full_adder dut(
		.sum(sum),
		.cin(cin),
		.cout(cout),
		.A(A),
		.B(B)
	);
	
	//apply stimuli
	initial begin
		{A,B,cin} = 3'b000; #10;
		{A,B,cin} = 3'b001; #10;
		{A,B,cin} = 3'b010; #10;
		{A,B,cin} = 3'b011; #10;
		{A,B,cin} = 3'b100; #10;
		{A,B,cin} = 3'b101; #10;
		{A,B,cin} = 3'b110; #10;
		{A,B,cin} = 3'b111; #10;

	end

endmodule