module moduleName (
    // ports
    input A, B, cin;
    output reg sum, carry, cout;

    //full-adder
    always @(*) begin
        case (A, B, cin, sum, carry, cout)
            3'b000: {cout, sum} = 3'b000;
            3'b001: {cout, sum} = 3'b001;
            3'b010: {cout, sum} = 3'b001;
            3'b011: {cout, sum} = 3'b010;
            3'b100: {cout, sum} = 3'b001;
            3'b101: {cout, sum} = 3'b010;
            3'b110: {cout, sum} = 3'b010;
            3'b111: {cout, sum} = 3'b011;
            default: 
        endcase
    end
);
    
endmodule