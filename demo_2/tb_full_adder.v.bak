module tb_full_adder;

    reg A, B, cin;      // inputs as registers
    wire sum, cout;     // outputs as wires

    // Instantiate the full adder
    full_adder dut (.sum(sum), .cout(cout), .A(A), .B(B), .cin(cin));

    initial begin
        $monitor("Time=%0t | A=%b B=%b cin=%b | sum=%b cout=%b", 
                 $time, A, B, cin, sum, cout);

        A=0; B=0; cin=0; #10;
        A=1; B=0; cin=0; #10;
        A=0; B=1; cin=0; #10;
        A=1; B=1; cin=0; #10;
        A=0; B=0; cin=1; #10;
        A=1; B=0; cin=1; #10;
        A=0; B=1; cin=1; #10;
        A=1; B=1; cin=1; #10;

        $finish;   // end simulation
    end

endmodule